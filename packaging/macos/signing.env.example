# Copy this file to packaging/macos/signing.env and source it before release builds.

# Required for app signing.
export APPLE_DEVELOPER_ID_APPLICATION="Developer ID Application: Your Name (TEAMID)"

# Required for installer signing.
export APPLE_DEVELOPER_ID_INSTALLER="Developer ID Installer: Your Name (TEAMID)"

# Preferred notarization flow: store credentials in keychain once, then reference the profile here.
export APPLE_KEYCHAIN_PROFILE="research-assistant-notary"

# One-time setup values used by packaging/macos/store_notary_credentials.sh.
# If you do not use APPLE_KEYCHAIN_PROFILE directly in CI, sign_and_notarize.py can also read these.
export APPLE_ID="your-apple-id@example.com"
export APPLE_TEAM_ID="TEAMID1234"
export APPLE_APP_SPECIFIC_PASSWORD="xxxx-xxxx-xxxx-xxxx"
